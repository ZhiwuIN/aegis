<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aegis.modules.log.mapper.SysLoginLogMapper">

    <resultMap id="BaseResultMap" type="com.aegis.modules.log.domain.entity.SysLoginLog">
        <id property="id" column="id"/>
        <result property="loginUsername" column="login_username"/>
        <result property="loginIp" column="login_ip"/>
        <result property="loginLocal" column="login_local"/>
        <result property="loginBrowser" column="login_browser"/>
        <result property="loginOs" column="login_os"/>
        <result property="loginTime" column="login_time"/>
        <result property="loginStatus" column="login_status"/>
        <result property="errorMessage" column="error_message"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,login_username,login_ip,login_local,login_browser,login_os,
        login_time,login_status,error_message
    </sql>

    <select id="selectAccessTrend" resultType="com.aegis.modules.common.domain.vo.AccessTrendVO">
        SELECT DATE_FORMAT(login_time, '%Y-%m-%d') AS date,
               COUNT(*)                            AS count
        FROM t_sys_login_log
        WHERE login_time >= DATE_SUB(CURDATE(), INTERVAL #{days} DAY)
          AND login_status = '0'
        GROUP BY DATE_FORMAT(login_time, '%Y-%m-%d')
        ORDER BY DATE_FORMAT(login_time, '%Y-%m-%d')
    </select>
</mapper>
