<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aegis.modules.user.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.aegis.modules.user.domain.entity.User">
        <id property="id" column="id"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
        <result property="version" column="version"/>
        <result property="remark" column="remark"/>
        <result property="deptId" column="dept_id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="email" column="email"/>
        <result property="sex" column="sex"/>
        <result property="phone" column="phone"/>
        <result property="avatar" column="avatar"/>
        <result property="status" column="status"/>
        <result property="lastLoginIp" column="last_login_ip"/>
        <result property="lastLoginTime" column="last_login_time"/>
    </resultMap>

    <resultMap id="SecurityUser" type="com.aegis.modules.user.domain.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="status" column="status"/>
        <collection property="permCodeList" ofType="java.lang.String">
            <result column="perm_code"/>
        </collection>
    </resultMap>

    <sql id="Base_Column_List">
        id,create_by,update_by,create_time,update_time,deleted,
        version,remark,dept_id,username,password,
        nickname,email,sex,phone,avatar,
        status,last_login_ip,last_login_time
    </sql>

    <select id="loadUserByUsername" resultMap="SecurityUser">
        SELECT u.id,
               u.username,
               u.PASSWORD,
               u.STATUS,
               p.perm_code AS perm_code
        FROM t_user u
                 LEFT JOIN t_user_role ur ON ur.user_id = u.id
                 LEFT JOIN t_role r ON ur.role_id = r.id AND r.deleted = 0 AND r.status = '0'
                 LEFT JOIN t_role_permission rp ON rp.role_id = r.id
                 LEFT JOIN t_permission p ON p.perm_code = rp.perm_code AND p.deleted = 0 AND p.status = '0'
        WHERE u.deleted = 0
          AND (u.username = #{username}
            OR u.email = #{username}
            OR u.phone = #{username})
    </select>
</mapper>
