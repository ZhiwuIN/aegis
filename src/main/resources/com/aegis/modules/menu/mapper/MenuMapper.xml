<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aegis.modules.menu.mapper.MenuMapper">

    <resultMap id="BaseResultMap" type="com.aegis.modules.menu.domain.entity.Menu">
        <id property="id" column="id"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
        <result property="version" column="version"/>
        <result property="remark" column="remark"/>
        <result property="menuName" column="menu_name"/>
        <result property="parentId" column="parent_id"/>
        <result property="orderNum" column="order_num"/>
        <result property="requestMethod" column="request_method"/>
        <result property="requestUri" column="request_uri"/>
        <result property="name" column="name"/>
        <result property="path" column="path"/>
        <result property="component" column="component"/>
        <result property="isFrame" column="is_frame"/>
        <result property="keepAlive" column="keep_alive"/>
        <result property="menuType" column="menu_type"/>
        <result property="hidden" column="hidden"/>
        <result property="status" column="status"/>
        <result property="perms" column="perms"/>
        <result property="icon" column="icon"/>
    </resultMap>

    <resultMap id="MenuRole" type="com.aegis.modules.menu.domain.entity.Menu" extends="BaseResultMap">
        <collection property="roleList" ofType="com.aegis.modules.role.domain.entity.Role">
            <result column="role_code" property="roleCode"/>
        </collection>
    </resultMap>

    <sql id="Base_Column_List">
        id,create_by,update_by,create_time,update_time,deleted,
        version,remark,menu_name,parent_id,order_num,request_method,request_uri,`name`
        `path`,component,is_frame,keep_alive,menu_type,hidden,`status`
        ,perms,icon
    </sql>

    <select id="getAllMenu" resultMap="MenuRole">
        SELECT DISTINCT m.*,
                        r.role_code AS role_code
        FROM t_menu m
                 INNER JOIN t_role_menu rm ON rm.menu_id = m.id
                 INNER JOIN t_role r ON r.id = rm.role_id
        WHERE m.request_uri IS NOT NULL
          AND m.deleted = 0
          AND m.status = '0'
          AND r.deleted = 0
          AND r.status = '0'
    </select>

    <select id="selectPermsByUserId" resultType="java.lang.String">
        SELECT DISTINCT m.perms
        FROM t_menu m
                 INNER JOIN t_role_menu rm ON rm.menu_id = m.id
                 INNER JOIN t_user_role ur ON ur.role_id = rm.role_id
                 INNER JOIN t_role r ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
          AND m.perms IS NOT NULL
          AND m.deleted = 0
          AND m.status = '0'
          AND r.deleted = 0
          AND r.status = '0'
    </select>

    <select id="selectMenuByUserId" resultType="com.aegis.modules.menu.domain.entity.Menu">
        SELECT DISTINCT m.*
        FROM t_menu m
                 INNER JOIN t_role_menu rm ON rm.menu_id = m.id
                 INNER JOIN t_user_role ur ON ur.role_id = rm.role_id
                 INNER JOIN t_role r ON r.id = ur.role_id
                 INNER JOIN t_user u ON u.id = ur.user_id
        WHERE u.id = #{userId}
          AND m.menu_type IN ('D', 'M')
          AND m.deleted = 0
          AND m.status = '0'
          AND r.deleted = 0
          AND r.status = '0'
        ORDER BY m.parent_id, m.order_num
    </select>
</mapper>
