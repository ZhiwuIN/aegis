# =============================================
# Aegis 环境变量配置示例
# 复制此文件为 .env 并修改为你的实际值
# Docker 启动时通过 --env-file 加载
# =============================================

# ---- Server ----
SERVER_PORT=8088

# ---- Upload Size ----
MAX_FILE_SIZE=2MB
MAX_REQUEST_SIZE=10MB

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DATABASE=1

# ---- MySQL ----
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/aegis?serverTimezone=Asia/Shanghai&useSSL=false
MYSQL_USERNAME=root
MYSQL_PASSWORD=your-mysql-password

# ---- Mail (SMTP) ----
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=your-email@163.com
MAIL_PASSWORD=your-email-authorization-code

# ---- JWT (必须修改! 使用随机长字符串) ----
JWT_SECRET=your-random-secret-key-at-least-64-characters-long
JWT_ACCESS_TOKEN_EXPIRATION=900
JWT_REFRESH_TOKEN_EXPIRATION=604800

# ---- File Storage ----
# 可选值: LOCAL, MINIO, ALIYUN_OSS, TENCENT_COS
FILE_PLATFORM=LOCAL
FILE_LOCAL_PATH=/opt/uploads/
FILE_LOCAL_SECRET_KEY=your-local-file-secret-key

# ---- Minio (FILE_PLATFORM=MINIO 时需要配置) ----
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=your-bucket-name

# ---- Knife4j API Docs ----
# 生产环境建议: KNIFE4J_ENABLE=false, KNIFE4J_PRODUCTION=true
KNIFE4J_ENABLE=true
KNIFE4J_PRODUCTION=false
KNIFE4J_USERNAME=aegis
KNIFE4J_PASSWORD=your-strong-password

# ---- Security ----
# 生产环境(HTTPS)应设为 true
COOKIE_SECURE=false

# ---- Freemarker ----
# 生产环境建议设为 true 开启模板缓存
FREEMARKER_CACHE=false

# ---- Demo Reset (演示环境数据重置) ----
DEMO_RESET_ENABLED=false
DEMO_RESET_CRON=0 0 * * * ?

# ---- CORS (逗号分隔多个域名) ----
CORS_ALLOWED_ORIGINS=https://aegis.example.cn

# ---- Logging ----
# 可选值: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=DEBUG

# ---- Task Scheduling ----
TASK_SCHEDULING_ENABLED=true
